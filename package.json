{
  "name": "ai-pr-guardian",
  "version": "1.0.0",
  "description": "GitHub Action that detects, scores, and gates AI-generated and low-quality PRs",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "github-actions",
    "code-quality",
    "pull-request",
    "anti-slop",
    "ai-detection",
    "code-review",
    "automation",
    "developer-tools",
    "open-source"
  ],
  "author": "ollieb89",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.15",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  }
}
